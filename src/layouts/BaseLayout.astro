---
import { ClientRouter } from "astro:transitions";
import FloatingWhatsAppButton from "../components/FloatingWhatsAppButton.astro";

const defaultTitle = "Aires Express Hotel | Hotel en Buenos Aires";
const defaultDescription =
  "Aires Express Hotel en Buenos Aires. Habitaciones cómodas, ubicación estratégica y contacto directo por WhatsApp para tu reserva.";
const defaultImage = "/images/Logo1080x1080.png";
const defaultKeywords = [
  "Aires Express Hotel",
  "hotel en Buenos Aires",
  "alojamiento en CABA",
  "habitaciones en Buenos Aires",
  "hotel céntrico"
];

const {
  title = defaultTitle,
  description = defaultDescription,
  image = defaultImage,
  imageAlt = "Aires Express Hotel",
  keywords = defaultKeywords,
  canonicalPath = Astro.url.pathname,
  type = "website",
  robots = "index, follow",
  noindex = false,
  structuredData
} = Astro.props;

const siteUrl = Astro.site ? new URL(Astro.site) : null;
const resolvedCanonical = canonicalPath
  ? siteUrl
    ? new URL(canonicalPath, siteUrl).toString()
    : canonicalPath
  : null;
const resolvedImage = siteUrl ? new URL(image, siteUrl).toString() : image;
const resolvedPageUrl = resolvedCanonical && resolvedCanonical.startsWith("http")
  ? resolvedCanonical
  : null;
const robotsContent = noindex ? "noindex, nofollow" : robots;
const keywordContent = Array.isArray(keywords) ? keywords.join(", ") : keywords;

const hotelSchema = {
  "@context": "https://schema.org",
  "@type": "Hotel",
  name: "Aires Express Hotel",
  description,
  image: [resolvedImage],
  telephone: "+54 9 11 4048-0054",
  email: "airesexpress@gmail.com",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Bartolomé Mitre 3410",
    addressLocality: "Cdad. Autónoma de Buenos Aires",
    addressRegion: "Buenos Aires",
    addressCountry: "AR"
  },
  sameAs: ["https://www.instagram.com/hotel_airesexpress"],
  ...(resolvedPageUrl ? { url: resolvedPageUrl } : {})
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Aires Express Hotel",
  description,
  ...(siteUrl ? { url: siteUrl.toString() } : {})
};

const customStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];

const jsonLdEntries = [webSiteSchema, hotelSchema, ...customStructuredData];
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywordContent} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Aires Express Hotel" />
    <meta name="theme-color" content="#ef476f" />
    <meta name="format-detection" content="telephone=yes" />

    <title>{title}</title>

    {resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}

    <meta property="og:site_name" content="Aires Express Hotel" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={resolvedImage} />
    <meta property="og:image:alt" content={imageAlt} />
    {resolvedPageUrl && <meta property="og:url" content={resolvedPageUrl} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/images/Logo1080x1080.png" />

    {jsonLdEntries.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)} />
    ))}

    <ClientRouter />
  </head>
  <body>
    <slot />
    <FloatingWhatsAppButton />
  </body>
</html>

<style is:global>
  html {
    overflow-x: hidden;
  }

  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation-duration: 0.35s;
    animation-timing-function: ease;
  }

  body {
    font-family: Arial, Helvetica, sans-serif;
    margin: 0;
    padding: 0;
    font-size: large;
    background: #f5f5f5;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .btn-primary {
    text-decoration: none;
    background: #ef476f;
    padding: 10px 18px;
    border-radius: 30px;
    color: white;
    transition: 0.4s ease;
  }
  
  .btn-primary:hover {
    color: #ef476f;
    background-color: white;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  [data-reveal] {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }

.search-bar {
  position: relative;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  background: rgba(156, 150, 150, 0.5);
  border-radius: 60px;
  padding: 12px;
  gap: 8px;
  box-shadow: 0 15px 40px rgba(0,0,0,0.12);
  box-sizing: border-box;
  min-width: 0;
}

.search-field {
  position: relative;
  flex: 1;
  min-width: 0;
  background: #f8f8f8;
  padding: 14px 20px;
  border-radius: 40px;
  display: flex;
  /* flex-direction: column; */
  gap: 10px;
  align-items: center;
  cursor: pointer;
  transition: 0.2s ease;
}

.search-field-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.search-field:hover {
  background: #ffffff;
  box-shadow: 0 8px 20px rgba(0,0,0,0.08);
}

.label {
  font-size: 12px;
  color: #8a8a8a;
  margin-bottom: 4px;
}

.value {
  font-size: 14px;
  font-weight: 500;
  color: #2b2b2b;
}

.divider {
  width: 1px;
  height: 50px;
  background: rgba(0,0,0,0.05);
}

.search-button {
  width: 58px;
  height: 58px;
  border-radius: 50%;
  background: #ef476f;
  border: none;
  color: white;
  font-size: 18px;
  cursor: pointer;
  box-shadow: 0 10px 25px rgba(239, 71, 111, 0.5);
  transition: 0.2s ease;
}

.search-button:hover {
  transform: scale(1.05);
}

.overlay-box {
  position: absolute;
  top: 115%;
  left: 0;
  width: max-content;
  background: white;
  border-radius: 20px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.15);
  padding: 24px;
  min-width: 300px;
  z-index: 20;
}


.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
}

.apply {
  width: 100%;
  background: #ef476f;
  color: white;
  border: none;
  padding: 10px;
  border-radius: 10px;
  cursor: pointer;
}

.rooms {
  width: 350px;
}

.room-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18px;
}

.room-desc {
  font-size: 12px;
  color: #888;
}

.counter {
  display: flex;
  align-items: center;
  gap: 10px;
}

.counter button {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 1px solid #ddd;
  background: white;
  cursor: pointer;
}


/* DayPicker Custom */
.rdp {
  margin: 0;
}

.overlay-box.calendar {
  min-width: 320px;
  width: max-content;
}

.rdp-day_selected {
  background: #ef476f !important;
  color: white !important;
  border-radius: 50%;
}

.rdp-day_range_middle {
  background: #fde2e7 !important;
}

.rdp-day {
  border-radius: 50%;
}

/* ROOM CAROUSEL */
.rooms-section {
  margin-top: 60px;
}

.section-title {
  text-align: center;
  font-size: 32px;
  margin-bottom: 40px;
}

.carousel-wrapper {
  position: relative;
}

.embla {
  overflow: hidden;
}

.embla__container {
  display: flex;
  gap: 24px;
}

.embla__slide {
  min-width: clamp(360px, 34vw, 430px);
}

@media (max-width: 1024px) {
  .embla__slide {
    min-width: 58%;
  }
}

@media (max-width: 768px) {
  .embla__slide {
    min-width: 86%;
  }

  .carousel-btn {
    display: none;
  }
}

.room-card {
  background: white;
  border-radius: 24px;
  max-width: 352px;
  overflow: hidden;
  /* box-shadow: 0 20px 50px rgba(0,0,0,0.08); */
  transition: 0.3s ease;
}

.room-card:hover {
  transform: translateY(-8px);
  /* box-shadow: 0 25px 60px rgba(0,0,0,0.15); */
}

.room-card img {
  width: 100%;
  height: 240px;
  object-fit: cover;
}

.room-content {
  padding: 20px;
}

.room-content h3 {
  margin: 0 0 10px 0;
}

.room-content p {
  font-size: 14px;
  color: #666;
  margin-bottom: 15px;
}

.room-meta {
  display: flex;
  gap: 20px;
  font-size: 14px;
  color: #444;
}

.room-meta span {
  display: flex;
  align-items: center;
  gap: 6px;
}

.room-preview-card {
  display: block;
  background: #ffffff;
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 24px;
  overflow: hidden;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.room-preview-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 18px 42px rgba(0, 0, 0, 0.08);
}

.room-preview-media {
  width: 100%;
  height: 240px;
  object-fit: cover;
  display: block;
}

.room-preview-body {
  padding: 20px;
}

.room-preview-title {
  margin: 0 0 10px;
  font-size: 20px;
  line-height: 1.2;
  color: #212121;
}

.room-preview-description {
  margin: 0 0 14px;
  font-size: 14px;
  line-height: 1.6;
  color: #6f6f6f;
}

.room-preview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14px;
  font-size: 14px;
  color: #4f4f4f;
}

.room-preview-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.carousel-btn {
  position: absolute;
  top: 40%;
  transform: translateY(-50%);
  background: white;
  border: none;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  box-shadow: 0 10px 25px rgba(0,0,0,0.15);
  cursor: pointer;
  z-index: 10;
}

.carousel-btn.left {
  left: -20px;
}

.carousel-btn.right {
  right: -20px;
}

.rooms-carousel .section-title {
  margin-bottom: 12px;
}

.carousel-mobile-hint {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 8px;
  font-size: 13px;
  color: #7a7a7a;
  margin-bottom: 14px;
}

.carousel-dots {
  display: flex;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
}

.carousel-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: none;
  background: #d6d6d6;
  cursor: pointer;
  transition: transform 0.2s ease, background-color 0.2s ease;
}

.carousel-dot.active {
  background: #ef476f;
  transform: scale(1.25);
}

@media (max-width: 980px) {
  .carousel-mobile-hint {
    display: inline-flex;
  }

  .search-bar {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    border-radius: 28px;
    padding: 12px;
  }

  .search-field {
    width: 100%;
    min-width: 0;
    padding: 14px 16px;
    box-sizing: border-box;
  }

  .value {
    font-size: 13px;
  }

  .search-button {
    width: 100%;
    height: 52px;
    border-radius: 18px;
    margin-left: 0;
  }

  .overlay-box {
    position: relative;
    top: auto;
    left: auto;
    width: 100%;
    min-width: 0;
    margin-top: 14px;
    box-sizing: border-box;
    padding: 18px;
  }

  .overlay-box.calendar {
    padding: 12px;
    min-width: 0;
    width: 100%;
  }

  .calendar .rdp-root {
    width: 100%;
    max-width: 100%;
    margin: 0;
    --rdp-day-width: 32px;
    --rdp-day-height: 32px;
    --rdp-day_button-width: 30px;
    --rdp-day_button-height: 30px;
    --rdp-nav_button-width: 1.7rem;
    --rdp-nav_button-height: 1.7rem;
    --rdp-weekday-padding: 0.3rem 0;
    --rdp-months-gap: 0.35rem;
  }

  .calendar .rdp-months {
    width: 100%;
    max-width: 100%;
  }

  .calendar .rdp-month {
    width: 100%;
    margin: 0;
  }

  .calendar .rdp-month_grid {
    width: 100%;
    table-layout: fixed;
  }

  .calendar .rdp-weekday,
  .calendar .rdp-day {
    text-align: center;
  }

  .calendar .rdp-caption_label {
    font-size: 0.95rem;
  }

  .calendar .rdp-weekday {
    font-size: 0.78rem;
  }

  .rooms {
    width: 100%;
  }
}

@media (max-width: 420px) {
  .calendar .rdp-root {
    --rdp-day-width: 30px;
    --rdp-day-height: 30px;
    --rdp-day_button-width: 28px;
    --rdp-day_button-height: 28px;
  }
}

 /* LOCATION TABS */
.location-section {
  padding: 120px 0;
  background: #f5f5f5;
}

.location-section h2 {
  text-align: center;
  margin-bottom: 50px;
  font-size: 32px;
}

.location-card {
  display: grid;
  grid-template-columns: 40% 60%;
  background: white;
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 25px 60px rgba(0,0,0,0.08);
}

.location-info {
  padding: 40px;
}

.rating {
  font-size: 14px;
  margin-bottom: 20px;
  color: #555;
}

.tabs {
  display: flex;
  gap: 25px;
  margin-bottom: 20px;
}

.tab {
  background: none;
  border: none;
  font-size: 14px;
  color: #777;
  cursor: pointer;
  padding-bottom: 6px;
  transition: 0.2s ease;
}

.tab.active {
  color: #ef476f;
  border-bottom: 2px solid #ef476f;
}

.places {
  list-style: none;
  padding: 0;
  margin: 0;
  margin-top: 20px;
}

.place-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid rgba(0,0,0,0.05);
  transition: 0.2s ease;
}

.place-item:last-child {
  border-bottom: none;
}

.place-item:hover {
  transform: translateX(4px);
}

.place-left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.place-name {
  font-weight: 500;
  color: #2b2b2b;
}

.place-distance {
  font-size: 14px;
  color: #8a8a8a;
}

.location-map iframe {
  width: 100%;
  height: 100%;
  border: 0;
}

@media (max-width: 1024px) {
  .location-card {
    grid-template-columns: 1fr;
  }

  .location-map {
    height: 300px;
  }
}

@media (max-width: 768px) {
  .location-section {
    padding: 80px 0;
  }

  .location-info {
    padding: 25px;
  }

  .tabs {
    gap: 15px;
  }

  .tab {
    font-size: 13px;
  }

  .place-item {
    padding: 12px 0;
  }

  .location-map {
    height: 250px;
  }
}
.place-item.selected {
  background: rgba(239, 71, 111, 0.05);
  border-radius: 8px;
}

.place-item.selected .place-name {
  color: #ef476f;
}



</style>
