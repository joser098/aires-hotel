---
import { rooms as roomCatalog } from "../data/rooms.js";
import { Menu, X } from "lucide-react";

const phone = "5491123456789";

const message = encodeURIComponent(
  "Hola, quiero más información sobre el Hotel Aires Express."
);

const roomLinks = roomCatalog.map((room) => ({
  title: room.title.replace("Habitacion ", ""),
  href: `/habitaciones/${room.slug}`
}));
---

<header class="navbar">
  <div class="container">
    <!-- Logo -->
    <div class="logo">
      <a href="/">
        <img src="/images/Logo.png" alt="Aires Express" height="70"/>
      </a>
    </div>

    <button
      id="menuToggle"
      class="menu-toggle"
      type="button"
      aria-label="Abrir menu"
      aria-expanded="false"
    >
      <span class="menu-open"><Menu size={22} /></span>
      <span class="menu-close hidden"><X size={22} /></span>
    </button>

    <!-- Nav -->
    <nav id="siteNav" class="nav-links">
      <a href="/" class="arrow">Inicio</a>

      <div class="dropdown">
        <button
          id="roomsBtn"
          class="nav-btn"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Habitaciones
          <span class="arrow">▾</span>
        </button>


        <div id="roomsMenu" class="dropdown-menu hidden">
          {roomLinks.map((room) => (
            <a href={room.href} class="arrow">{room.title}</a>
          ))}
        </div>
      </div>

      <a
        class="btn-primary"
        href={`https://wa.me/${phone}?text=${message}`}
        target="_blank"
      >
        Contáctanos
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  function setupNavbarDropdown() {
    if (window.__navbarDropdownCleanup) {
      window.__navbarDropdownCleanup();
      window.__navbarDropdownCleanup = null;
    }

    const btn = document.getElementById("roomsBtn");
    const menu = document.getElementById("roomsMenu");
    const menuToggle = document.getElementById("menuToggle");
    const siteNav = document.getElementById("siteNav");
    const menuOpenIcon = menuToggle?.querySelector(".menu-open");
    const menuCloseIcon = menuToggle?.querySelector(".menu-close");

    if (!btn || !menu || !menuToggle || !siteNav || !menuOpenIcon || !menuCloseIcon) {
      return;
    }

    const navAnchors = siteNav.querySelectorAll("a");

    const handleButtonClick = (event) => {
      event.stopPropagation();
      const willOpen = menu.classList.contains("hidden");
      menu.classList.toggle("hidden");
      btn.setAttribute("aria-expanded", willOpen ? "true" : "false");
    };

    const closeMobileMenu = () => {
      siteNav.classList.remove("nav-open");
      menuToggle.setAttribute("aria-expanded", "false");
      menuOpenIcon.classList.remove("hidden");
      menuCloseIcon.classList.add("hidden");
      menu.classList.add("hidden");
      btn.setAttribute("aria-expanded", "false");
    };

    const openMobileMenu = () => {
      siteNav.classList.add("nav-open");
      menuToggle.setAttribute("aria-expanded", "true");
      menuOpenIcon.classList.add("hidden");
      menuCloseIcon.classList.remove("hidden");
    };

    const handleMenuToggle = (event) => {
      event.stopPropagation();

      if (siteNav.classList.contains("nav-open")) {
        closeMobileMenu();
        return;
      }

      openMobileMenu();
    };

    const handleDocumentClick = (event) => {
      const target = event.target;

      if (!(target instanceof Node)) {
        return;
      }

      if (!menu.contains(target) && !btn.contains(target)) {
        menu.classList.add("hidden");
      }

      if (!siteNav.contains(target) && !menuToggle.contains(target)) {
        closeMobileMenu();
      }
    };

    const handleResize = () => {
      if (window.innerWidth > 980) {
        closeMobileMenu();
      }
    };

    const handleNavLinkClick = () => {
      if (window.innerWidth <= 980) {
        closeMobileMenu();
      }
    };

    btn.addEventListener("click", handleButtonClick);
    menuToggle.addEventListener("click", handleMenuToggle);
    document.addEventListener("click", handleDocumentClick);
    window.addEventListener("resize", handleResize);
    navAnchors.forEach((anchor) => anchor.addEventListener("click", handleNavLinkClick));

    window.__navbarDropdownCleanup = () => {
      btn.removeEventListener("click", handleButtonClick);
      menuToggle.removeEventListener("click", handleMenuToggle);
      document.removeEventListener("click", handleDocumentClick);
      window.removeEventListener("resize", handleResize);
      navAnchors.forEach((anchor) =>
        anchor.removeEventListener("click", handleNavLinkClick)
      );
    };
  }

  document.addEventListener("astro:page-load", setupNavbarDropdown);
  setupNavbarDropdown();
</script>

<style>
.navbar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  padding-top: 24px;
  z-index: 10;
  background: transparent;
}

.navbar .container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
  position: relative;
}

.container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.nav-links {
  display: flex;
  gap: clamp(10px, 1.8vw, 22px);
  align-items: center;
}

.logo img {
  display: block;
  height: 70px;
  width: auto;
}

.menu-toggle {
  display: none;
  align-items: center;
  justify-content: center;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.16);
  background: rgba(255,255,255,0.08);
  color: white;
  cursor: pointer;
  backdrop-filter: blur(10px);
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 14px;
  border-radius: 20px;
  transition: 0.4s ease;
}

.nav-btn:hover {
  background: rgba(255,255,255,0.15);
}

.nav-links .arrow,
.nav-btn {
  color: white;
  text-decoration: none;
  font-size: 1rem;
  background: none;
  border: none;
  cursor: pointer;
}

.dropdown {
  position: relative;
}

.dropdown-menu {
  position: absolute;
  top: 120%;
  left: 0;
  background: white;
  border-radius: 16px;
  box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  padding: 10px 0;
  min-width: 220px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  animation: fadeIn 0.2s ease;
  z-index: 20;
}

.dropdown-menu .arrow {
  padding: 12px 20px;
  color: #333;
  transition: 0.2s;
}

.dropdown-menu .arrow:hover {
  background: #f5f5f5;
}

.contact-btn {
  padding: 8px 18px;
  background: #ef476f;
  color: white;
  border-radius: 25px;
  text-decoration: none;
}

.hidden {
  display: none;
}

.contact-btn {
  padding: 10px 20px;
  background: #ef476f;
  color: white;
  border-radius: 999px;
  font-weight: 500;
  transition: 0.2s ease;
}

.contact-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(239, 71, 111, 0.4);
}


@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-5px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@media (max-width: 980px) {
  .navbar {
    padding-top: 16px;
  }

  .navbar .container {
    padding: 0 16px;
    gap: 12px;
  }

  .logo img {
    height: 52px;
  }

  .menu-toggle {
    display: inline-flex;
    position: relative;
    z-index: 12;
  }

  .nav-links {
    position: absolute;
    top: calc(100% + 12px);
    left: 16px;
    right: 16px;
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
    padding: 16px;
    border-radius: 20px;
    background: rgba(18, 18, 20, 0.92);
    backdrop-filter: blur(14px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.22);
    max-height: min(70vh, 560px);
    overflow-y: auto;
  }

  .nav-links.nav-open {
    display: flex;
  }

  .nav-links > .arrow,
  .nav-links > .btn-primary,
  .dropdown,
  .nav-btn {
    width: 100%;
  }

  .nav-links > .arrow,
  .nav-btn,
  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 14px;
    border-radius: 14px;
    box-sizing: border-box;
  }

  .nav-links > .arrow,
  .nav-btn {
    background: rgba(255,255,255,0.06);
  }

  .dropdown-menu {
    position: static;
    margin-top: 8px;
    min-width: 100%;
    border-radius: 14px;
    max-height: 220px;
    overflow-y: auto;
  }
}

</style>
