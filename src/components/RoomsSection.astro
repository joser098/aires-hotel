<style>
  .rooms-section {
    padding: 60px 30px;
    background: #f5f5f5;
  }
  
  .rooms-header {
    text-align: center;
    padding: 60px 0px;
    max-width: 600px;
    margin: 0 auto 60px auto;
  }

  .rooms-header h2 {
    font-size: 32px;
    margin-bottom: 16px;
    color: #2b2b2b;
  }

  .rooms-header p {
    font-size: 16px;
    color: #6e6e6e;
    line-height: 1.6;
  }
</style>
