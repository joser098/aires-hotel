---
import SearchBarClient from "./SearchBarClient.jsx";
---

<div class="search-wrapper">
  <SearchBarClient client:load />
</div>

<style>
.search-wrapper {
  position: absolute;
  bottom: -40px;
  left: 50%;
  transform: translateX(-50%);
  width: min(1200px, calc(100% - 48px));
  z-index: 10;
}

@media (max-width: 980px) {
  .search-wrapper {
    position: static;
    bottom: auto;
    left: auto;
    right: auto;
    transform: none;
    width: calc(100% - 32px);
    max-width: none;
    inset: auto;
    margin: 28px 16px 0;
  }
}
</style>
