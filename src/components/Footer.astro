---
const year = new Date().getFullYear();
---

<footer class="footer" data-reveal>
  <div class="container footer-content">

    <!-- LEFT -->
    <div class="footer-column">
      <h4>Dirección</h4>
      <p>
        Bartolomé Mitre 3410<br />
        Cdad. Autónoma de Buenos Aires
      </p>

      <h4 class="mt">Contacto</h4>
      <p>
        Teléfono: +54 9 11 4048-0054<br />
        airesexpress@gmail.com
      </p>
    </div>

    <!-- CENTER -->
    <div class="footer-logo">
      <img src="/images/Logo.png" alt="Aires Express" height="70"/>
      <!-- <div class="logo-text">
        <span>Aires Express</span>
        <small>HOTEL</small>
      </div> -->
    </div>

    <!-- RIGHT -->
    <div class="footer-social">
      <a href="https://www.instagram.com/hotel_airesexpress" aria-label="Instagram">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <rect x="2" y="2" width="20" height="20" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="18" cy="6" r="1"></circle>
        </svg>
      </a>

      <!-- <a href="#" aria-label="Facebook">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M18 2h-3a4 4 0 0 0-4 4v3H8v4h3v9h4v-9h3l1-4h-4V6a1 1 0 0 1 1-1h3z"></path>
        </svg>
      </a> -->
    </div>

  </div>

  <div class="footer-bottom">
    © {year} Aires Express Hotel. Todos los derechos reservados.
  </div>
</footer>
<style>
  .footer {
  background: #F7F7F7;
  padding-top: 60px;
  border-top: 1px solid rgba(0,0,0,0.06);
}

.footer-content {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 40px;
  padding-bottom: 40px;
}

/* LEFT */
.footer-column h4 {
  font-size: 14px;
  margin-bottom: 8px;
  color: #2b2b2b;
}

.footer-column p {
  font-size: 13px;
  color: #777;
  line-height: 1.6;
  margin: 0 0 15px 0;
}

.footer-column .mt {
  margin-top: 20px;
}

/* CENTER LOGO */
.footer-logo {
  display: flex;
  align-items: center;
  gap: 12px;
}

.logo-mark {
  width: 30px;
  height: 30px;
  border-left: 3px solid #ef476f;
  border-bottom: 3px solid #ef476f;
  transform: skewY(-10deg);
}

.logo-text span {
  display: block;
  font-weight: 600;
  font-size: 18px;
}

.logo-text small {
  font-size: 10px;
  letter-spacing: 2px;
  color: #ef476f;
}

/* SOCIAL */
.footer-social {
  display: flex;
  justify-content: flex-end;
  gap: 15px;
}

.footer-social a {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #444;
  transition: 0.3s ease;
}

.footer-social a:hover {
  background: #ef476f;
  color: white;
  transform: translateY(-3px);
}

/* BOTTOM */
.footer-bottom {
  text-align: center;
  padding: 18px 0;
  font-size: 12px;
  color: #888;
  background: #fafafa;
}

/* RESPONSIVE */
@media (max-width: 768px) {
  .footer-content {
    grid-template-columns: 1fr;
    text-align: center;
    gap: 30px;
  }

  .footer-social {
    justify-content: center;
  }

  .footer-logo {
    justify-content: center;
  }
}

</style>
