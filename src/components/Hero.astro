---
import SearchBar from "./SearchBar.astro";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <h1>Bienvenidos al Hotel Aires Express</h1>
      <p>¡Aquí empieza tu mejor estadía!</p>
    </div>
  </div>

  <SearchBar />
</section>


<style>
.hero {
  position: relative;
  min-height: 640px;
  display: flex;
  align-items: center;
  padding: 120px 0 96px;
  box-sizing: border-box;

  background-image: url("/images/obelisco.png");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.hero-inner {
  width: 100%;
  position: relative;
  z-index: 2;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: start;
  justify-content: center;
  max-width: 600px;
  color: white;
}

.hero-content p {
  margin: 14px 0 0;
  font-size: clamp(16px, 2vw, 22px);
  line-height: 1.5;
}

.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.6),
    rgba(0,0,0,0.2)
  );
}

.hero-content h1 {
  font-size: 3rem;
  margin: 0;
}

@media (max-width: 768px) {
  .hero {
    min-height: auto;
    padding: 104px 0 32px;
    align-items: flex-start;
  }

  .hero-content {
    max-width: 100%;
    text-align: left;
  }

  .hero-content h1 {
    font-size: clamp(34px, 10vw, 48px);
    line-height: 1.05;
  }

  .hero-content p {
    font-size: 16px;
    max-width: 28ch;
  }
}
</style>
