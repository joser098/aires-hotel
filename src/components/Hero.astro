---
import SearchBar from "./SearchBar.astro";
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <h1>Bienvenidos al Hotel Aires Express</h1>
      <p>¡Aquí empieza tu mejor estadía!</p>
    </div>
  </div>

  <SearchBar />
</section>


<style>
.hero {
  position: relative;
  min-height: clamp(560px, 86vh, 760px);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: clamp(120px, 17vw, 170px) 0 clamp(112px, 12vw, 150px);
  box-sizing: border-box;
  justify-content: center;
  overflow: visible;
  background-image: url("/images/obelisco.png");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.hero-inner {
  width: 100%;
  position: relative;
  z-index: 2;
}

.hero-content {
  display: flex;
  flex-direction: column;
  gap: 14px;
  align-items: start;
  justify-content: center;
  max-width: min(640px, 100%);
  color: white;
}

.hero-content h1,
.hero-content p {
  opacity: 0;
  transform: translateY(22px);
  animation: heroElementIn 0.8s cubic-bezier(0.2, 0.65, 0.2, 1) forwards;
}

.hero-content h1 {
  animation-delay: 0.12s;
}

.hero-content p {
  animation-delay: 0.3s;
}

.hero :global(.search-wrapper) {
  opacity: 0;
  animation: heroFadeIn 0.9s cubic-bezier(0.2, 0.65, 0.2, 1) 0.45s forwards;
}

.hero-content p {
  margin: 0;
  font-size: clamp(18px, 2.2vw, 24px);
  line-height: 1.4;
  max-width: 34ch;
}

.hero::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(0,0,0,0.6),
    rgba(0,0,0,0.2)
  );
}

.hero-content h1 {
  margin: 0;
  font-size: clamp(38px, 6vw, 64px);
  line-height: 1.05;
  text-wrap: balance;
}

@keyframes heroElementIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes heroFadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero-content h1,
  .hero-content p {
    animation: none;
    opacity: 1;
    transform: none;
  }

  .hero :global(.search-wrapper) {
    animation: none;
    opacity: 1;
  }
}

@media (max-width: 1024px) {
  .hero {
    min-height: clamp(520px, 80vh, 680px);
    padding: 116px 0 112px;
  }

  .hero-content {
    max-width: 560px;
  }
}

@media (max-width: 768px) {
  .hero {
    min-height: auto;
    padding: 104px 0 28px;
    align-items: flex-start;
    background-position: 62% center;
  }

  .hero-content {
    max-width: 100%;
    text-align: left;
  }

  .hero-content h1 {
    font-size: clamp(32px, 11vw, 48px);
    line-height: 1.05;
  }

  .hero-content p {
    font-size: 16px;
    max-width: 30ch;
  }

  .hero::after {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.62),
      rgba(0, 0, 0, 0.28)
    );
  }
}

@media (max-width: 480px) {
  .hero {
    padding-top: 96px;
  }

  .hero-content h1 {
    font-size: clamp(30px, 11.5vw, 40px);
  }
}
</style>
