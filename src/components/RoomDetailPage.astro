---
import SearchBar from "./SearchBar.astro";
import RoomGallery from "./RoomGallery.jsx";
import RoomPreviewCard from "./RoomPreviewCard.jsx";

const {
  eyebrow = "Aires Express",
  title = "Habitacion Doble",
  heroImage = "/images/rooms/room.png",
  gallery = [],
  description = [],
  services = [],
  relatedRooms = []
} = Astro.props;

const galleryImages = gallery.length > 0
  ? gallery
  : [
      heroImage,
      heroImage,
      heroImage,
      heroImage,
      heroImage,
      heroImage
    ];
---

<main class="room-page">
  <section class="room-hero">
    <div class="container">
      <div class="hero-card">
        <img src={heroImage} alt={title} class="hero-image" />
        <div class="hero-overlay"></div>
        <div class="hero-copy">
          <span>{eyebrow}</span>
          <h1>{title}</h1>
        </div>
      </div>
    </div>
  </section>

  <section class="room-content">
    <div class="container">
      <div class="room-shell">
        <section class="gallery-section">
          <RoomGallery images={galleryImages} title={title} client:load />
        </section>

        <section class="description-section">
          {description.map((paragraph: any) => (
            <p>{paragraph}</p>
          ))}
        </section>

        <section class="services-section">
          <h2>Servicios de Aires Express</h2>
          <div class="services-grid">
            {services.map((service: any) => (
              <span class="service-chip">{service}</span>
            ))}
          </div>
        </section>

        <section class="booking-section">
          <div class="booking-header">
            <h2>Reserva</h2>
            <p>Consulta disponibilidad y arma tu estadia desde aqui.</p>
          </div>
          <div class="booking-bar">
            <SearchBar />
          </div>
        </section>

        <section class="related-section">
          <h2>Otras habitaciones</h2>
          <div class="related-grid">
            {relatedRooms.map((room: any) => (
              <RoomPreviewCard
                href={room.href ?? "/habitaciones"}
                title={room.title}
                image={room.image}
                description={room.description}
                people={room.guests === 1 ? "1 persona" : `${room.guests} personas`}
                beds={room.beds}
              />
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</main>

<style>
  .room-page {
    padding: 0;
    background: #f5f5f5;
  }

  .room-hero {
    padding: 0;
  }

  .room-hero .container {
    max-width: 100%;
    padding: 0;
  }

  .hero-card {
    position: relative;
    border-radius: 0;
    overflow: hidden;
    min-height: 320px;
    box-shadow: none;
  }

  .hero-image {
    width: 100%;
    height: 320px;
    object-fit: cover;
    display: block;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(18, 18, 20, 0.45), rgba(18, 18, 20, 0.12)),
      linear-gradient(180deg, rgba(18, 18, 20, 0.08), rgba(18, 18, 20, 0.35));
  }

  .hero-copy {
    position: absolute;
    left: 50%;
    bottom: 34px;
    width: min(1200px, calc(100% - 48px));
    transform: translateX(-50%);
    color: #fff;
    z-index: 1;
  }

  .hero-copy span {
    display: inline-block;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 10px;
    opacity: 0.85;
  }

  .hero-copy h1 {
    margin: 0;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 0.95;
    text-shadow: 0 8px 24px rgba(0, 0, 0, 0.22);
  }

  .room-content {
    padding: 40px 0 80px;
  }

  .room-shell {
    background: #ffffff;
    border-radius: 32px;
    padding: 36px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.08);
  }

  .gallery-section,
  .description-section,
  .services-section,
  .booking-section {
    margin-bottom: 40px;
  }

  :global(.gallery-grid) {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 18px;
  }

  :global(.gallery-grid img),
  :global(.gallery-strip img),
  :global(.room-preview-media) {
    width: 100%;
    display: block;
    object-fit: cover;
  }

  :global(.room-gallery button) {
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
  }

  :global(.gallery-mobile) {
    display: none;
  }

  :global(.gallery-tile) {
    overflow: hidden;
    border-radius: 24px;
    position: relative;
    transition: transform 0.28s ease, box-shadow 0.28s ease;
  }

  :global(.gallery-tile::after) {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.08));
    opacity: 0;
    transition: opacity 0.28s ease;
  }

  :global(.gallery-tile:hover) {
    transform: translateY(-4px);
    box-shadow: 0 18px 34px rgba(0, 0, 0, 0.12);
  }

  :global(.gallery-tile:hover::after) {
    opacity: 1;
  }

  :global(.gallery-main img) {
    height: 420px;
  }

  :global(.gallery-side) {
    display: grid;
    gap: 18px;
  }

  :global(.gallery-side img) {
    height: 201px;
  }

  :global(.gallery-strip) {
    margin-top: 18px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  :global(.gallery-thumb) {
    border-radius: 18px;
    overflow: hidden;
    transition: transform 0.24s ease, box-shadow 0.24s ease, opacity 0.24s ease;
  }

  :global(.gallery-thumb:hover) {
    transform: translateY(-3px);
    box-shadow: 0 14px 26px rgba(0, 0, 0, 0.12);
  }

  :global(.gallery-strip img) {
    height: 140px;
  }

  :global(.gallery-overlay) {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: rgba(10, 10, 12, 0.88);
    backdrop-filter: blur(8px);
    z-index: 60;
    animation: gallery-overlay-in 0.28s ease;
  }

  :global(.gallery-modal) {
    position: relative;
    width: 100vw;
    height: 100vh;
    max-height: none;
    background: rgba(18, 18, 22, 0.98);
    border-radius: 0;
    padding: 78px clamp(14px, 2.6vw, 40px) 18px;
    box-shadow: none;
    border: none;
    animation: gallery-modal-in 0.34s cubic-bezier(0.22, 1, 0.36, 1);
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    overflow-x: hidden;
  }

  :global(.gallery-close) {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    position: absolute;
    top: 18px;
    right: clamp(14px, 2.6vw, 40px);
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.25);
    border-radius: 999px;
    padding: 8px 12px;
    font-size: 13px;
    color: #f1f1f1;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  :global(.gallery-close span) {
    display: block;
    line-height: 1;
  }

  :global(.gallery-close:hover) {
    background: rgba(255, 255, 255, 0.18);
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.42);
    transform: translateY(-1px);
  }

  :global(.gallery-stage) {
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) 54px;
    align-items: center;
    gap: clamp(10px, 2vw, 24px);
    flex: 1;
    min-height: 0;
  }

  :global(.gallery-arrow) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: #666;
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  :global(.gallery-arrow:hover) {
    background: #ffffff;
    color: #111;
    transform: scale(1.06);
  }

  :global(.gallery-preview) {
    width: min(94vw, 1700px);
    max-height: calc(100vh - 210px);
    margin: 0 auto;
    display: block;
    object-fit: contain;
    border-radius: 12px;
    box-shadow: 0 24px 56px rgba(0, 0, 0, 0.28);
    animation: gallery-image-in 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(.gallery-filmstrip) {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 16px;
    overflow-x: auto;
    padding: 6px 2px 4px;
  }

  :global(.film-thumb) {
    width: 84px;
    height: 62px;
    flex: 0 0 auto;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid transparent;
    opacity: 0.75;
    transition: border-color 0.2s ease, opacity 0.2s ease, transform 0.2s ease;
  }

  :global(.film-thumb.active) {
    border-color: #ef476f;
    opacity: 1;
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 14px 24px rgba(239, 71, 111, 0.28);
  }

  :global(.film-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.mobile-gallery-stage) {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #3a3b43;
    padding: 0;
  }

  :global(.mobile-gallery-image-button) {
    width: 100%;
    display: block;
  }

  :global(.mobile-gallery-image) {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  :global(.mobile-gallery-arrow) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 42px;
    height: 42px;
    border-radius: 10px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.92);
    color: #6b6b6b;
    box-shadow: 0 12px 22px rgba(0, 0, 0, 0.14);
    z-index: 2;
  }

  :global(.mobile-gallery-arrow.left) {
    left: 10px;
  }

  :global(.mobile-gallery-arrow.right) {
    right: 10px;
  }

  :global(.mobile-gallery-arrow:disabled) {
    opacity: 0.42;
    cursor: default;
  }

  :global(.mobile-gallery-counter) {
    position: absolute;
    right: 10px;
    bottom: 10px;
    z-index: 2;
    padding: 6px 10px;
    border-radius: 10px;
    font-size: 14px;
    color: #ffffff;
    background: rgba(0, 0, 0, 0.42);
    backdrop-filter: blur(4px);
  }

  @keyframes gallery-overlay-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes gallery-modal-in {
    from {
      opacity: 0;
      transform: translateY(18px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes gallery-image-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .description-section p {
    margin: 0 0 16px;
    color: #5a5a5a;
    line-height: 1.8;
    font-size: 15px;
  }

  .description-section p:last-child {
    margin-bottom: 0;
  }

  .services-section h2,
  .booking-header h2,
  .related-section h2 {
    margin: 0 0 18px;
    font-size: 28px;
    color: #1f1f1f;
  }

  .services-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .service-chip {
    padding: 10px 16px;
    border-radius: 999px;
    background: #fff5f7;
    color: #d83b67;
    font-size: 14px;
    font-weight: 600;
  }

  .booking-header p {
    margin: 0;
    color: #6e6e6e;
  }

  .booking-bar {
    position: relative;
    min-height: 128px;
    margin-top: 24px;
    padding-top: 12px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  @media (max-width: 1024px) {
    .room-shell {
      padding: 28px;
    }

    :global(.gallery-grid),
    .related-grid {
      grid-template-columns: 1fr;
    }

    :global(.gallery-main img),
    :global(.gallery-side img),
    :global(.room-preview-media) {
      height: 280px;
    }

    :global(.gallery-strip) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .room-page {
      padding-top: 0;
    }

    .room-hero {
      padding: 0;
    }

    .hero-card,
    .hero-image {
      min-height: 240px;
      height: 240px;
    }

    .hero-copy {
      left: 50%;
      bottom: 20px;
      width: calc(100% - 48px);
    }

    .room-shell {
      padding: 20px;
      border-radius: 24px;
    }

    :global(.gallery-strip) {
      grid-template-columns: 1fr;
    }

    .booking-bar {
      min-height: 200px;
    }

    :global(.gallery-overlay) {
      padding: 0;
    }

    :global(.gallery-modal) {
      padding: 70px 10px 12px;
    }

    :global(.gallery-stage) {
      display: block;
      position: relative;
    }

    :global(.gallery-arrow) {
      width: 46px;
      height: 46px;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 3;
    }

    :global(.gallery-arrow.left) {
      left: 8px;
    }

    :global(.gallery-arrow.right) {
      right: 8px;
    }

    :global(.gallery-preview) {
      width: 100%;
      max-width: none;
      max-height: calc(100vh - 185px);
    }

    :global(.gallery-filmstrip) {
      justify-content: center;
      gap: 8px;
      margin-top: 10px;
      padding-left: 0;
      padding-right: 0;
    }

    :global(.film-thumb) {
      width: 64px;
      height: 48px;
    }

    :global(.gallery-close) {
      top: 14px;
      right: 10px;
      padding: 7px 10px;
      font-size: 12px;
    }

    :global(.gallery-desktop) {
      display: none;
    }

    :global(.gallery-mobile) {
      display: block;
    }
  }
</style>
