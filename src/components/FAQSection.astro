---
import { ChevronDown } from "lucide-react"
const faqs = [
  {
    question: "¿Cuándo se puede hacer el check-in y el check-out en Aires Express?",
    answer:
      "El check-in es a partir de las 14:00 hs y el check-out hasta las 11:00 hs.",
  },
  {
    question: "¿El hotel incluye desayuno?",
    answer:
      "Sí, el desayuno continental está incluido en todas las reservas.",
  },
  {
    question: "¿Se aceptan mascotas?",
    answer:
      "No se permiten mascotas dentro del establecimiento.",
  },
  {
    question: "¿Cómo puedo cancelar mi reserva?",
    answer:
      "Puedes comunicarte por WhatsApp o correo electrónico para gestionar la cancelación.",
  },
]

---
<section class="faq-section">
  <div class="container">

    <h2>Preguntas Frecuentes</h2>

    <div class="faq-box">

      <div class="faq-item">
        {
          faqs.map(faq => (
            <div class="faq-item">
              <button class="faq-question">
                {faq.question}
                <span class="faq-arrow"><ChevronDown size={16} /></span>
              </button>
              <div class="faq-answer">
                {faq.answer}
              </div>
            </div>
          ))
        }
    </div>

  </div>
</section>

<script is:inline>
  const items = document.querySelectorAll(".faq-item");

  items.forEach(item => {
    const btn = item.querySelector(".faq-question");

    btn.addEventListener("click", () => {
      const isActive = item.classList.contains("active");

      items.forEach(i => i.classList.remove("active"));

      if (!isActive) {
        item.classList.add("active");
      }
    });
  });
</script>


<style>
.faq-section {
  padding: 120px 0;
  background: #f5f5f5;
}

.faq-section h2 {
  margin-bottom: 40px;
}

.faq-box {
  background: white;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.08);
}

.faq-item {
  border-bottom: 1px solid rgba(0,0,0,0.08);
}

.faq-item:last-child {
  border-bottom: none;
}

.faq-question {
  width: 100%;
  padding: 22px 24px;
  background: none;
  border: none;
  font-size: 15px;
  font-weight: 500;
  text-align: left;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.faq-arrow {
  font-size: 18px;
  transition: transform 0.3s ease;
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, padding 0.3s ease;
  padding: 0 24px;
  font-size: 14px;
  color: #555;
}

.faq-item.active .faq-answer {
  max-height: 200px;
  padding: 0 24px 20px 24px;
}

.faq-item.active .faq-arrow {
  transform: rotate(180deg);
}

@media (max-width: 768px) {
  .faq-section {
    padding: 80px 0;
  }

  .faq-question {
    font-size: 14px;
  }
}

</style>
