---
import {
  Coffee,
  Wifi,
  AirVent,
  BellRing,
  Tv,
  ParkingCircle
} from "lucide-react";
---

<section class="services-section" data-reveal>
  <div class="container">

    <div class="services-header">
      <h2>Servicios</h2>
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit,
        sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
      </p>
    </div>

    <div class="services-grid">

      <div class="service-item">
        <div class="icon">
          <Coffee size={26} strokeWidth={1.5} />
        </div>
        <span>Desayuno</span>
      </div>

      <div class="service-item">
        <div class="icon">
          <Wifi size={26} strokeWidth={1.5} />
        </div>
        <span>Wi-Fi</span>
      </div>

      <div class="service-item">
        <div class="icon">
          <AirVent size={26} strokeWidth={1.5} />
        </div>
        <span>Aire acondicionado</span>
      </div>

      <div class="service-item">
        <div class="icon">
          <BellRing size={26} strokeWidth={1.5} />
        </div>
        <span>Recepción 24h</span>
      </div>

      <div class="service-item">
        <div class="icon">
          <Tv size={26} strokeWidth={1.5} />
        </div>
        <span>Televisión por cable</span>
      </div>

      <div class="service-item">
        <div class="icon">
          <ParkingCircle size={26} strokeWidth={1.5} />
        </div>
        <span>Estacionamiento</span>
      </div>

    </div>
  </div>
</section>
<style>
.services-section {
  padding: 30px 0;
  background: #f5f5f5;
}

.services-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 60px auto;
}

.services-header h2 {
  font-size: 32px;
  margin-bottom: 16px;
  color: #2b2b2b;
}

.services-header p {
  font-size: 16px;
  color: #6e6e6e;
  line-height: 1.6;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 50px 40px;
  justify-items: center;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  text-align: center;
}

.service-item span {
  font-size: 14px;
  color: #444;
}

.icon {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 15px 35px rgba(0,0,0,0.08);
  transition: 0.3s ease;
}

.icon svg {
  color: #777;
}

.service-item:hover .icon {
  transform: translateY(-6px);
  box-shadow: 0 20px 45px rgba(0,0,0,0.12);
}

@media (max-width: 1024px) {
  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* @media (max-width: 600px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
} */

</style>
