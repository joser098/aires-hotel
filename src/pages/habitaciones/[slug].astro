---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import RoomDetailPage from "../../components/RoomDetailPage.astro";
import { rooms } from "../../data/rooms.js";

export function getStaticPaths() {
  return rooms.map((room) => ({
    params: { slug: room.slug },
    props: {
      room,
      relatedRooms: rooms
        .filter((candidate) => candidate.slug !== room.slug)
        .slice(0, 3)
        .map((candidate) => ({
          title: candidate.title,
          image: candidate.heroImage,
          guests: candidate.guests,
          beds: candidate.beds,
          href: `/habitaciones/${candidate.slug}`
        }))
    }
  }));
}

const { room, relatedRooms } = Astro.props;
const roomDescription = room.description?.[0] ?? "Habitación en Aires Express Hotel.";
const roomSchema = {
  "@context": "https://schema.org",
  "@type": "HotelRoom",
  name: room.title,
  description: roomDescription,
  bed: room.beds,
  occupancy: {
    "@type": "QuantitativeValue",
    maxValue: room.guests
  },
  amenityFeature: room.services.map((service) => ({
    "@type": "LocationFeatureSpecification",
    name: service,
    value: true
  }))
};
---

<BaseLayout
  title={`${room.title} | Aires Express Hotel`}
  description={roomDescription}
  keywords={[
    room.title,
    "Aires Express Hotel",
    "habitaciones en Buenos Aires",
    "hotel en CABA"
  ]}
  canonicalPath={`/habitaciones/${room.slug}`}
  image={room.heroImage}
  imageAlt={`${room.title} en Aires Express Hotel`}
  structuredData={roomSchema}
>
  <Navbar />
  <RoomDetailPage
    eyebrow={room.eyebrow}
    title={room.title}
    heroImage={room.heroImage}
    gallery={room.gallery}
    description={room.description}
    services={room.services}
    relatedRooms={relatedRooms}
  />
  <Footer />
</BaseLayout>
