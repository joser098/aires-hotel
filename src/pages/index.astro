---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import RoomsSection from "../components/RoomsSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import LocationSection from "../components/LocationSection.astro";
import FAQSection from "../components/FAQSection.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Aires Express Hotel | Hotel en Buenos Aires"
  description="Reservá en Aires Express Hotel y disfrutá una estadía cómoda en Buenos Aires, con habitaciones funcionales y atención directa."
  keywords={[
    "Aires Express Hotel",
    "hotel en Buenos Aires",
    "alojamiento en CABA",
    "reservas de hotel",
    "habitaciones en Buenos Aires"
  ]}
  canonicalPath="/"
  image="/images/obelisco.png"
  imageAlt="Vista de Buenos Aires desde Aires Express Hotel"
>
  <Navbar />
  <Hero/>
  <RoomsSection />
  <ServicesSection />
  <LocationSection />
  <FAQSection />
  <Footer />
</BaseLayout>
